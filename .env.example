# ─────────────────────────────────────────────
# MedScan AI — LLM Provider Configuration
# ─────────────────────────────────────────────

# Choose ONE provider:
# Supported: openrouter | openai | anthropic | groq | xai | gemini | mistral
LLM_PROVIDER=openrouter

# Your API key for the selected provider
LLM_API_KEY=sk-or-your-key-here

# Model to use (provider-specific format)
# Examples:
#   Free (OpenRouter):
#     openrouter → meta-llama/llama-3.2-11b-vision-instruct:free
#     openrouter → google/gemma-2-9b-it:free
#     openrouter → openrouter/auto
#   Cost-Effective (< 1 cent/req):
#     openrouter → google/gemini-3-flash-preview (User Tested)
#     openrouter → google/gemini-1.5-flash
#     openrouter → openai/gpt-4o-mini
#     gemini     → gemini-1.5-flash
#     openai     → gpt-4o-mini

LLM_MODEL=google/gemini-1.5-flash

# Rate limiting (optional - requires Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MedScan AI
MAX_FILE_SIZE_MB=5
RATE_LIMIT_PER_HOUR=10
