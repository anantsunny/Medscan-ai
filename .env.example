# ─────────────────────────────────────────────
# MedScan AI — LLM Provider Configuration
# ─────────────────────────────────────────────

# Choose ONE provider:
# Supported: openrouter | openai | anthropic | groq | xai | gemini | mistral
LLM_PROVIDER=openrouter

# Your API key for the selected provider
LLM_API_KEY=sk-or-your-key-here

# Model to use (provider-specific format)
# Examples:
#   openrouter  → anthropic/claude-3-5-sonnet, openai/gpt-4o, google/gemini-2.0-flash
#   openai      → gpt-4o, gpt-4-turbo
#   anthropic   → claude-3-5-sonnet-20241022, claude-opus-4
#   groq        → llama-3.3-70b-versatile, mixtral-8x7b-32768
#   xai         → grok-2-vision-1212
#   gemini      → gemini-2.0-flash, gemini-1.5-pro
#   mistral     → pixtral-12b-2409 (vision support)
LLM_MODEL=anthropic/claude-3-5-sonnet

# Rate limiting (optional - requires Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MedScan AI
MAX_FILE_SIZE_MB=5
RATE_LIMIT_PER_HOUR=10
